# Usuario dedicado al runtime de OpenClaw.
WORK_USER=eric
WORK_HOME=/home/eric

# Directorio base de trabajo visible para apps creativas.
STUDIO_DIR=/home/eric/Studio
STUDIO_DIR_MODE=755
STUDIO_PROJECT_DIR_MODE=755

# Directorio de estado de OpenClaw.
OPENCLAW_STATE_DIR=/home/eric/.openclaw
OPENCLAW_CREDENTIALS_MODE=700

# Host y puerto esperados del gateway local.
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# Canales habilitados.
PRIMARY_CHAT_CHANNEL=whatsapp
OPENCLAW_STUDIO_ACTIONS_ENABLE=true
OPENCLAW_STUDIO_ACTIONS_PLUGIN_DIR=/home/eric/Documents/OpenClaw/plugins/studio-actions
OPENCLAW_STUDIO_ACTIONS_COMMAND_PREFIX=studio
OPENCLAW_STUDIO_ACTIONS_CHANNELS=whatsapp
OPENCLAW_STUDIO_ACTIONS_ALLOW_GROUP_MESSAGES=false

# Binarios o rutas principales.
BLENDER_BIN=/snap/bin/blender
COMFYUI_DIR=/home/eric/ComfyUI
COMFYUI_REPO_URL=https://github.com/comfyanonymous/ComfyUI.git
COMFYUI_REPO_REF=master
COMFYUI_VENV_DIR=/home/eric/ComfyUI/.venv
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_INSTALL=true
COMFYUI_CREATE_VENV=true
COMFYUI_RECREATE_VENV_IF_PIP_MISSING=true
COMFYUI_INSTALL_REQUIREMENTS=false
COMFYUI_ENABLE_SERVICE=false
COMFYUI_MANAGER_INSTALL=true
COMFYUI_MANAGER_DIR=/home/eric/ComfyUI/custom_nodes/comfyui-manager
COMFYUI_MANAGER_REPO_URL=https://github.com/ltdrdata/ComfyUI-Manager.git
COMFYUI_MANAGER_REPO_REF=main
COMFYUI_MANAGER_INSTALL_REQUIREMENTS=true

# Politicas de convergencia del bootstrap.
DISABLE_GNOME_AUTOMOUNT=true
HARDEN_OPENCLAW=true
ENABLE_OPENCLAW_SERVICES=true
CREATE_STUDIO_DIRS=true
VERIFY_INTERNAL_NVME_UNMOUNTED=true
CHECK_DANGEROUS_GROUPS=true

# Modo por defecto de los scripts:
# audit  -> solo comprobar
# apply  -> aplicar cambios seguros
DEFAULT_MODE=audit
